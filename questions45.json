[
  { "q": "வரிசைப்படுத்தி சரியான விடையைத் தேர்ந்தெடு. i) விருந்தே புதுமை – 1. செயங்கொண்டார் ii) இல்லறவியல் – 2. இளங்கோவடிகள் iii) சிலப்பதிகாரம் – 3. தொல்காப்பியர் iv) கலிங்கத்துப்பரணி – 4. திருவள்ளுவர்", "options": ["1, 2, 3, 4", "4, 3, 2, 1", "4, 3, 1, 2", "3, 4, 2, 1"], "answer": "3, 4, 2, 1" },
  { "q": "மினசோட்டா தமிழ்ச்சங்கம் அமைந்துள்ள இடம் எது?", "options": ["அமெரிக்கா", "இலங்கை", "மொரிசியஸ்", "மலேசியா"], "answer": "அமெரிக்கா" },
  { "q": "தொல்காப்பியர் விருந்து என்பதை என்னவென்று கூறியுள்ளார்?", "options": ["தொன்மை", "புதுமை", "இளமை", "முதுமை"], "answer": "புதுமை" },
  { "q": "“………தொல்லோர் சிறப்பின் விருந்தெதிர் கோடலும் இழந்த என்னை ” – என்று குறிப்பிடும் நூல் எது? இது யாருடைய கூற்றாக அமைகிறது?", "options": ["கம்பராமாயணம், சீதை", "சிலப்பதிகாரம், கண்ணகி", "நளவெண்பா, தமயந்தி", "சீவகசிந்தாமணி, காந்தருவதத்தை"], "answer": "சிலப்பதிகாரம், கண்ணகி" },
  { "q": "“பொருந்து செல்வமும் கல்வியும் பூத்தலால் வருந்தி வந்தவர்க்கு ஈதலும் வைகலும் விருந்தும் அன்றி விளைவான யாவையே” – என்று குறிப்பிடும் நூல்?", "options": ["கம்பராமாயணம்", "பெரிய புராணம்", "சிலப்பதிகாரம்", "மணிமேகலை"], "answer": "கம்பராமாயணம்" },
  { "q": "“அல்லில் ஆயினும் விருந்து வரின் உவக்கும்” என்று நள்ளிரவிலும் உணவிடும் குடும்பத் தலைவியின் விருந்தோம்பலைச் சிறப்பித்துக் கூறும் நூல்.", "options": ["குறுந்தொகை", "அகநானூறு", "நற்றிணை", "புறநானூறு"], "answer": "நற்றிணை" },
  { "q": "‘காலின் ஏழடிப் பின் சென்று’ என விருந்தினரை வழியனுப்பும் தமிழரின் இயல்பைக் குறிப்பிடும் நூல்", "options": ["சிறுபாணாற்றுப்படை", "பெரும்பாணாற்றுப்படை", "பொருநராற்றுப்படை", "கூத்தராற்றுப்படை"], "answer": "பொருநராற்றுப்படை" },
  { "q": "“விருந்தினரும் வறியவரும் நெருங்கி யுண்ண மேன்மேலும் முகமலரும் மேலோர் போல” – இவ்வடிகள் இடம் பெற்றுள்ள நூல்?", "options": ["கம்பராமாயணம்", "கலிங்கத்துப்பரணி", "முக்கூடற்பள்ளு", "பெரியபுராணம்"], "answer": "கலிங்கத்துப்பரணி" },
  { "q": "அன்று விதைத்துவிட்டு வந்த நெல்லை அரித்து வந்து, பின் சமைத்துச் சிவனடியாருக்கு விருந்து படைத்தவர் யார்? இக்காட்சி இடம் பெறும் நூல் எது?", "options": ["சாக்கியநாயனார், பெரிய புராணம்", "இளையான்குடி மாறநாயனார், பெரிய புராணம்", "காரைக்கால் அம்மையார், அற்புத திருவந்தாதி", "சுந்தரர், திருத்தொண்டத்தொகை"], "answer": "இளையான்குடி மாறநாயனார், பெரிய புராணம்" },
  { "q": "நெய்தல் நிலத்தவர் பாணர்களை வரவேற்றுக் கொடுத்தவையாகச் சிறுபாணாற்றுப்படை குறிப்பிடுபவை எவை?", "options": ["குழல் மீன் கறியும் பிறவும்", "ஆரல் மீன் கறியும் உப்பும்", "உப்பும் முத்தும்", "மீன் கறியும் நண்டும்"], "answer": "குழல் மீன் கறியும் பிறவும்" },
  { "q": "“இலையை மடிப்பதற்கு முந்தைய வினாடிக்கு முன்பாக மறுக்க மறுக்க பரிமாறப்பட்ட கூடுதல் இட்லியில் நீண்டு கொண்டிருந்தது பிரியங்களின் நீள் சரடு” – என்னும் கவிதைக்கு உரியவர் யார்?", "options": ["அம்சப்பிரியா", "பா.விஜய்", "சிநேகன்", "நா. முத்துக்குமார்"], "answer": "அம்சப்பிரியா" },
  { "q": "“பலர்புகு வாயில் அடைப்பக் கடவுநர் வருவீர் உளீரோ”- என்று குறிப்பிடும் நூல் எது?", "options": ["நற்றிணை", "குறுந்தொகை", "பதிற்றுப்பத்து", "பரிபாடல்"], "answer": "குறுந்தொகை" },
  { "q": "“மருந்தே ஆயினும் விருந்தோடு உண்” என்று பாடியவர் யார்? நூல் எது?", "options": ["ஔவையார், ஆத்திச்சூடி", "ஔவையார், கொன்றைவேந்தன்", "குமரகுருபரர், நீதிநெறி விளக்கம்", "வள்ளலார், ஜீவகாருண்ய ஒழுக்கம்"], "answer": "ஔவையார், கொன்றைவேந்தன்" },
  { "q": "அமெரிக்காவின் மினசோட்டா தமிழ்ச்சங்கம் ஆண்டுதோறும் கொண்டாடும் விழா", "options": ["வாழையிலை விருந்து விழா", "இறைச்சி உணவு விருந்து விழா", "வேட்டி சேலை உடுத்தும் விழா", "நவதானிய விழா"], "answer": "வாழையிலை விருந்து விழா" },
  { "q": "திருக்குறளில் விருந்தோம்பல் அதிகாரம் இடம்பெறும் இயல்", "options": ["இல்லறவியல்", "பாயிரவியல்", "அரசியல்", "துறவறவியல்"], "answer": "இல்லறவியல்" },
  { "q": "விருந்தினரைப் போற்றிப் பேணல் பழந்தமிழர் மரபு என்பதை உணர்த்தியவர்.", "options": ["திருவள்ளுவர்", "தொல்காப்பியர்", "இளங்கோவடிகள்", "செயங்கொண்டார்"], "answer": "இளங்கோவடிகள்" },
  { "q": "கல்வியும் செல்வமும் பெற்ற பெண்கள், விருந்தும் ஈகையும் செய்வதாகக் குறிப்பிட்டுள்ளவர்", "options": ["கம்பர்", "தொல்காப்பியர்", "இளங்கோவடிகள்", "செயங்கொண்டார்"], "answer": "கம்பர்" },
  { "q": "இளையான்குடி மாறநாயனாரின் விருந்தளிக்கும் திறன் பற்றிக் குறிப்பிடும் நூல்?", "options": ["பெரிய புராணம்", "நற்றிணை", "பொருநராற்றுப்படை", "கம்பராமாயணம்"], "answer": "பெரிய புராணம்" },
  { "q": "விருந்தோம்பல் பற்றிய 17ஆம் நூற்றாண்டுச் சுவரோவியம் காணப்படுமிடம்", "options": ["சிதம்பரம்", "மதுரை", "மாமல்லபுரம்", "திருச்சி"], "answer": "சிதம்பரம்" },
  { "q": "விருந்தோம்பலை வலியுறுத்த ஓர் அதிகாரத்தையே படைத்த புலவர்", "options": ["ஒளவையார்", "திருவள்ளுவர்", "கபிலர்", "கம்பர்"], "answer": "திருவள்ளுவர்" },
  { "q": "“வரகரிசிச் சோறும் வழுதுணங்காய் வாட்டும் முரமுரெனவே புளித்த மோரும்” – எனப் பாடியவர்", "options": ["ஒளவையார்", "தொல்காப்பியர்", "கம்பர்", "திருவள்ளுவர்"], "answer": "ஒளவையார்" },

  

  { "q": "காசிக்காண்டத்தை இயற்றியவர் யார்?", "options": ["துளசிதாசர்","அதிவீரராம பாண்டியர்","ஔவையார்","பெருஞ்சித்திரனார்"], "answer": "அதிவீரராம பாண்டியர்" },
  { "q": "காசிக்காண்டத்தின் இல்லொழுக்கம் பற்றிய பகுதி எத்தனையாவது பாடல்?", "options": ["பதினான்காவது","பதினாறாவது","பதின்மூன்றாவது","பதினேழாவது"], "answer": "பதினேழாவது" },
  { "q": "முத்துக் குளிக்கும் கொற்கையின் அரசர்?", "options": ["அதிவீரராம பாண்டியர்","கிள்ளிவளவன்","செங்குட்டுவன்","இரண்டாம் புலிகேசி"], "answer": "அதிவீரராம பாண்டியர்" },
  { "q": "அதிவீரராம பாண்டியரின் பட்டப்பெயர்", "options": ["சீவலபேரி பாண்டி","சீவலமாறன்","மாறவர்மன்","மாறன்வழுதி"], "answer": "சீவலமாறன்" },
  { "q": "அதிவீரராம பாண்டியர் இயற்றாத நூலைக் கண்டறிக.", "options": ["நைடதம்","வாயு சம்கிதை","திருக்கருவை அந்தாதி","சடகோபர் அந்தாதி"], "answer": "சடகோபர் அந்தாதி" },

  
  {
    "q": "பொருத்திக் காட்டுக. i) நன்மொழி – 1. பெயரெச்சம் ii) வியத்தல் – 2. வியங்கோள் வினைமுற்று iii) வருக – 3. தொழிற்பெயர் iv) உரைத்த – 4. பண்புத்தொகை",
    "options": [
      "4, 3, 2, 1",
      "3, 4, 2, 1",
      "2, 1, 3, 4",
      "4, 2, 1, 3"
    ],
    "answer": "4, 3, 2, 1"
  },

  { "q": "உப்பிலாக் கூழ் இட்டாலும் உண்பதே அமிர்தம் ஆகும் – என்று குறிப்பிடும் நூல் எது?", "options": ["சீவக சிந்தாமணி","விவேக சிந்தாமணி","மணிமேகலை","நளவெண்பா"], "answer": "விவேக சிந்தாமணி" },
  { "q": "‘அருகுற’ என்பதன் பொருள் என்ன?", "options": ["அருகில்","தொலைவில்","அழிவில்","அழுகிய"], "answer": "அருகில்" },
  { "q": "முகமன் எனப்படுவது", "options": ["ஒருவரை நலம் வினவிக்கூறும் சொற்கள்","ஒருவரை எதிர்த்துப் பேசும் சொற்கள்","கருத்துகளை வரவேற்கும் சொற்கள்","அரசர் உரையாடல் சொற்கள்"], "answer": "ஒருவரை நலம் வினவிக்கூறும் சொற்கள்" },
  { "q": "விருந்தோம்பல் செய்யும் இல்லற ஒழுக்கத்தின் பண்புகள் எத்தனை?", "options": ["எட்டு","ஒன்பது","ஆறு","பத்து"], "answer": "ஒன்பது" },

  { "q": "வெற்றிவேற்கை என்னும் நூலின் ஆசிரியர்", "options": ["அதிவீரராம பாண்டியர்","கரிகாலன்","பாரி","பாண்டியன் நெடுஞ்செழியன்"], "answer": "அதிவீரராம பாண்டியர்" },
  { "q": "நறுந்தொகை என்னும் நூலின் ஆசிரியர்", "options": ["அதிவீரராம பாண்டியர்","கரிகாலன்","பாரி","பாண்டியன் நெடுஞ்செழியன்"], "answer": "அதிவீரராம பாண்டியர்" },
