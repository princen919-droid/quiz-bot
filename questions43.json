{ "q": "புதிய உரைநடை என்னும் நூலினை எழுதியவர்", "options": ["க. அப்பாதுரை", "எழில் முதல்வன்", "பாவாணர்", "இளங்குமரனார்"], "answer": "எழில் முதல்வன்" },
{ "q": "எழில் முதல்வனின் இயற்பெயர்", "options": ["மா. இராமலிங்கம்", "க. அப்பாதுரை", "பாவாணர்", "இளங்குமரனார்"], "answer": "மா. இராமலிங்கம்" },
{ "q": "எழில் முதல்வனின் சாகித்திய அகாதெமி பரிசு பெற்ற நூல்", "options": ["புதிய உரைநடை", "இனிக்கும் நினைவுகள்", "யாதுமாகி நின்றாய்", "எங்கெங்கு காணினும்"], "answer": "புதிய உரைநடை" },
{ "q": "எழில் முதல்வன் கற்றல் கற்பித்தல் பணியை மேற்கொண்ட கல்லூரி", "options": ["புதுக்கல்லூரி", "மாநிலக் கல்லூரி", "இராணி மேரிக்கல்லூரி", "குடந்தை அரசு ஆடவர் கல்லூரி"], "answer": "மாநிலக் கல்லூரி" },
{ "q": "சங்கப் புலவரிடம் இணையத் தமிழன் எவ்விலக்கியங்களைக் குறித்து உரையாடிக் கொண்டிருந்தான்?", "options": ["சங்க இலக்கியம்", "பக்தி இலக்கியம்", "உரைநடை இலக்கியம்", "சிற்றிலக்கியம்"], "answer": "உரைநடை இலக்கியம்" },
{ "q": "“உவமையும் பொருளும் வேற்றுமை ஒழிவித்து ஒன்றென மாட்டின் அது உருவகமாகும்” – என்றவர்", "options": ["தொல்காப்பியர்", "பவணத்தியார்", "தண்டி", "அகத்தியர்"], "answer": "தண்டி" },
{ "q": "“இயற்கை பதித்து வைத்த இரண்டு பெரிய நிலைக் கண்ணாடிகளைப் போல் வடபுறமும் தென்புறமும் நீர் நிறைந்த கண்மாய்கள்” என்று குறிஞ்சிமலர் நூலில் நா. பார்த்தசாரதி பயன்படுத்திய நயம்", "options": ["உவமை", "உருவகம்", "எடுத்துக்காட்டு உவமையணி", "சிற்றிலக்கியம்"], "answer": "உவமை" },
{ "q": "எடுத்துக்காட்டு உவமையணியை உரைநடையில் பயன்படுத்துகையில் அதனை எப்படி அழைப்பர்?", "options": ["இலக்கணை", "இணை ஒப்பு", "முரண்படு மெய்ம்மை", "சொல்முரண்"], "answer": "இணை ஒப்பு" },
{ "q": "குடிசையின் ஒருபக்கம் கோபுரங்கள் மறுபக்கம்; பசித்த வயிறுகள் ஒரு பக்கம் புளிச் சேப்பக்காரர்கள் மறுபக்கம்; மெலிந்த எலும்புக் கூடுகள் ஒருபக்கம் பருத்த தொந்திகள் மறுபக்கம் – தோழர் ப. ஜீவானந்தம் உரைநடை எதற்கு எடுத்துக்காட்டு?", "options": ["எதிரிணை இயைபு", "முரண்படு மெய்ம்மை", "இலக்கணை", "சொல்முரண்"], "answer": "எதிரிணை இயைபு" },
{ "q": "உணர்வுகளைத் தூண்டி எழுப்புவதில் வெற்றிபெறுவன?", "options": ["உவமையை விட உருவகமே", "உருவகத்தை விட உவமையே", "எதுகையை விட மோனையே", "கேள்வியிலே பதில் இருப்பது போல"], "answer": "உவமையை விட உருவகமே" },
