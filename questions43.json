{ "q": "முத்தினையும் அமிழ்தினையும் தருவதாகச் சந்தக்கவிமணி தமிழழகனார் குறிப்பிடுவது எதை?", "options": ["மூங்கில்", "கடல்", "மழை", "தேவர்கள்"], "answer": "கடல்" },
{ "q": "தமிழ் அணிகலன்களாகப் பெற்றவை எவை?", "options": ["சங்க இலக்கியங்கள்", "ஐம்பெருங்காப்பியங்கள்", "ஐஞ்சிறு காப்பியங்கள்", "நீதி இலக்கியங்கள்"], "answer": "ஐம்பெருங்காப்பியங்கள்" },
{ "q": "இரட்டுறமொழிதல் அணியின் வேறுபெயர் யாது?", "options": ["வேற்றுமை அணி", "பிறிதுமொழிதல் அணி", "சொற்பொருள் பின்வருநிலையணி", "சிலேடை அணி"], "answer": "சிலேடை அணி" },
{ "q": "ஒரு சொல்லோ, சொற்றொடரோ இருபொருள்பட வருவது எது?", "options": ["இரட்டுறமொழிதல் அணி", "வேற்றுமை அணி", "உவமை அணி", "உருவக அணி"], "answer": "இரட்டுறமொழிதல் அணி" },
{ "q": "சந்தக்கவிமணி எனக் குறிப்பிடப்படும் தமிழழகனாரின் இயற்பெயர் என்ன?", "options": ["சண்முகமணி", "சண்முகசுந்தரம்", "ஞானசுந்தரம்", "ஆறுமுகம்"], "answer": "சண்முகசுந்தரம்" },
{ "q": "தமிழழகனார் எத்தனை சிற்றிலக்கிய நூல்களைப் படைத்துள்ளார்?", "options": ["பத்து", "பன்னிரண்டு", "பதினான்கு", "பதினாறு"], "answer": "பன்னிரண்டு" },
{ "q": "முத்தமிழ் துய்ப்பதால் என்னும் பாடல் இடம் பெற்றுள்ள தொகுப்பு யாது?", "options": ["எட்டுத்தொகை", "பத்துப்பாட்டு", "சிற்றிலக்கியங்கள்", "தனிப்பாடல் திரட்டு"], "answer": "தனிப்பாடல் திரட்டு" },
