{ "q": "செந்தமிழ்ச் சொற்பிறப்பியல் அகரமுதலித் திட்ட இயக்குநராகப் பணியாற்றியவர் யார்?", "options": ["தேவநேயப் பாவாணர்","வெள்ளைவாரணார்","இளங்குமரனார்","பெருந்தேவனார்"], "answer": "தேவநேயப் பாவாணர்" },

{ "q": "உலகத் தமிழ்க் கழகத்தை நிறுவித் தலைவராக இருந்தவர் யார்?", "options": ["தனிநாயகம் அடிகள்","தேவநேயப் பாவாணர்","இளங்குமரனார்","மு. வரதராசனார்"], "answer": "தேவநேயப் பாவாணர்" },

{ "q": "போர்ச்சுகீசு நாட்டின் தலைநகர் எது?", "options": ["லெபனான்","லிசுபன்","கெய்ரோ","ஹராரே"], "answer": "லிசுபன்" },

{ "q": "இந்திய மொழிகளிலேயே மேலை நாட்டு எழுத்துருவில் முதலில் அச்சேறிய மொழி எது?", "options": ["இந்தி","தமிழ்","தெலுங்கு","வங்காளம்"], "answer": "தமிழ்" },

{ "q": "கார்டிலா என்னும் போர்ச்சுகீசிய நூல் தமிழில் மொழிபெயர்க்கப்பட்டதைக் குறிப்பிடுவது எது?", "options": ["ஆறாம் உலகத் தமிழ் மாநாட்டு மலர்","நான்காம் உலகத் தமிழ் மாநாட்டு மலர்","செம்மொழி மாநாட்டு மலர்","தமிழிலக்கிய வரலாறு மு.வ."], "answer": "ஆறாம் உலகத் தமிழ் மாநாட்டு மலர்" },

{ "q": "கொழுந்தாடை என்பது யாது?", "options": ["நெல், புல் ஆகியவற்றின் கொழுந்து","புளி, வேம்பு முதலியவற்றின் கொழுந்து","தென்னை, பனை முதலியவற்றின் கொழுந்து","கரும்பின் நுனிப்பகுதி"], "answer": "கரும்பின் நுனிப்பகுதி" },


{ "q": "‘தமிழ், ஆழி இரண்டுக்கும் பொருள்படும் படியான’ – இரட்டுற மொழிதலணி அமைய பாடிய ஆசிரியர் யார்?", "options": ["தேவநேயப் பாவாணர்", "பாவலரேறு பெருஞ்சித்திரனார்", "தமிழழகனார்", "எழில் முதல்வன்"], "answer": "தமிழழகனார்" },
{ "q": "கடல் தரும் சங்குகளின் வகைகள் எத்தனை?", "options": ["இரண்டு", "மூன்று", "நான்கு", "ஐந்து"], "answer": "மூன்று" },
