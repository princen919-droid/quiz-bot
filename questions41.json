{ "q": "பல்லவர் காலச் சிற்பங்களுக்குச் சிறந்த சான்று ……………………..", "options": ["மாமல்லபுரம்","பிள்ளையார் பட்டி","திரிபுவனவீரேசுவரம்","தாடிக்கொம்பு"], "answer": "மாமல்லபுரம்" },
{ "q": "திருநாதர்குன்றில் ஒரு பாறையில் புடைப்புச் சிற்பங்களாக உள்ளவை ………..", "options": ["விலங்கு உருவங்கள்","தீர்த்தங்கரர் உருவங்கள்","தெய்வ உருவங்கள்","நாட்டியம் ஆடும் பாவை உருவங்கள்"], "answer": "தீர்த்தங்கரர் உருவங்கள்" },
{ "q": "விழுப்புண்பட்டு இறந்த வீரருக்கு நடப்படுவது எது …………", "options": ["மைல்கல்","சுடுகல்","நடுகல்","கருங்கல்"], "answer": "நடுகல்" },
{ "q": "சிற்பிகள் …………. என சிறப்பிக்கப்பட்டனர்.", "options": ["கல்லோவியர்கள்","கற்கவிஞர்கள்","கற்சொல்லோவியர்கள்","சுவரோவியர்கள்"], "answer": "கற்கவிஞர்கள்" },
{ "q": "கழுகுமலை கோவில் சிற்பங்கள் ………. காலத்தவையாகும்.", "options": ["நாயக்கர்","பல்லவர்","பாண்டியர்","சோழர்"], "answer": "பாண்டியர்" },
{ "q": "தமிழ்நாடு தொழில்நுட்பக் கல்வி இயக்ககம் வெளியிட்ட நூல்…………", "options": ["சிற்பக்கலை","தமிழக சிற்பங்கள்","சிற்பமும் சிந்தனையும்","சிற்பச்செந்நூல்"], "answer": "சிற்பச்செந்நூல்" },
{ "q": "நடுகல் பற்றிக் குறிப்பிடும் இலக்கணநூல்", "options": ["தொல்காப்பியம்","நன்னூல்","புறப்பொருள் வெண்பாமாலை","இலக்கண விளக்கம்"], "answer": "தொல்காப்பியம்" },
{ "q": "மாளிகைகளில் சுதைச் சிற்பங்கள் இருந்ததைக் குறிப்பிடும் காப்பியம் எது?", "options": ["சீவகசிந்தாமணி","மணிமேகலை","நளவெண்பா","சிலப்பதிகாரம்"], "answer": "மணிமேகலை" },
{ "q": "நாயக்கர்கால சிற்பக்கலை நுட்பத்துக்குச் சான்றாகும் கோவில் எது?", "options": ["மூதூர் பெருமாள் கோவில்","பேரூர் சிவன் கோவில்","காஞ்சி கயிலாயநாதர் கோவில்","சீனிவாசநல்லூர் இரங்கநாதர் கோவில்"], "answer": "பேரூர் சிவன் கோவில்" },
{ "q": "திருவரங்கக்கோவில் யாருடைய காலத்துக் கட்டடக் கலைக்குச் சான்றாகிறது.", "options": ["பாண்டியர்","சோழர்","பல்லவர்","சேரர்"], "answer": "சோழர்" },


{ "q": "‘பொதுவர்கள் பொலி உறப் போர் அடித்திடும்’ நிலப்பகுதி ……………….", "options": ["குறிஞ்சி","நெய்தல்","முல்லை","கெடுதல்"], "answer": "முல்லை" },
{ "q": "இருபதாம் நூற்றாண்டின் தனித்தமிழ் பெருங்காப்பியம்.", "options": ["கம்பராமாயணம்","இராவணகாவியம்","தண்ணீர்த்தேசம்","பொன்னியின் செல்வன்"], "answer": "இராவணகாவியம்" },
{ "q": "இராவண காவியத்தின் பாடல்கள்", "options": ["2100","2500","3100","3500"], "answer": "3100" },
{ "q": "இருபத்தைந்து நாளில் திருக்குறளுக்கு உரை எழுதியவர்.", "options": ["புலவர் குழந்தை","மு. வரதராசனார்","சாலமன் பாப்பையா","பரிமேலழகர்"], "answer": "புலவர் குழந்தை" },
{ "q": "யாப்பதிகாரம், தொடையதிகாரம் எழுதியவர்", "options": ["பெருந்தேவனார்","வாணிதாசன்","வரந்தருவார்","புலவர் குழந்தை"], "answer": "புலவர் குழந்தை" },
{ "q": "“மன்னிய” – என்பதன் இலக்கணக்குறிப்பு.", "options": ["பெயரெச்சம்","வினையெச்சம்","தொழிற்பெயர்","வியங்கோள் வினைமுற்று"], "answer": "பெயரெச்சம்" },
{ "q": "“பூவை” – என்பது எப்பறவையைக் குறிக்கும்.", "options": ["காகம்","ஆறுமணிக்குருவி","நாகணவாய்ப்பறவை","நாரை"], "answer": "நாகணவாய்ப்பறவை" },
{ "q": "எருதின் கொம்பினைப்போல் இருந்த காய் எது?", "options": ["பாலைக்காய்","பாகற்காய்","ஏலக்காய்","வாழைக்காய்"], "answer": "பாலைக்காய்" },
{ "q": "காஞ்சியும், வஞ்சியும் பூக்கும் நிலம்", "options": ["குறிஞ்சி","முல்லை","மருதம்","நெய்தல்"], "answer": "மருதம்" },
{ "q": "கொன்றை , ஆம்பல், மூங்கில் ஆகியவற்றால் ஆனது ……………..", "options": ["முக்கூடை","முக்குழல்","முத்தளிர்","முக்கொம்பு"], "answer": "முக்குழல்" },



{ "q": "இராமாயணத்தில் எதிர்நிலை மாந்தராகப் படைக்கப்பட்டவன்", "options": ["இராமன்","அனுமன்","இராவணன்","குகன்"], "answer": "இராவணன்" },
{ "q": "“மரை முகம்” – என்பதன் இலக்கணக் குறிப்பு", "options": ["உம்மைத்தொகை","உவமைத்தொகை","உருவகம்","உரிச்சொற்றொடர்"], "answer": "உவமைத்தொகை" },
{ "q": "புரைதபப் பறித்துக் காஞ்சிப் புனை நிழல் அருந்துவாரே – இதில் அமைந்துள்ள நயம்", "options": ["அடிமோனை","சீர்மோனை","அடிஎதுகை","சீர்எதுகை"], "answer": "அடிமோனை" },
{ "q": "“வருமலை அளவி” – வருமலை என புலவர் எதனைக் குறிப்பிடுகிறார்.", "options": ["கடற்காகம்","கடற்காளான்","கடலாமை","கடல் அலை"], "answer": "கடல் அலை" },
{ "q": "கரிக்குருத்து என்பதன் பொருள் யாது?", "options": ["சேவற்கொண்டை","யானைத்தந்தம்","மான்கொம்பு","மயிற்தோகை"], "answer": "யானைத்தந்தம்" },
{ "q": "‘போர்’ அடிக்கும் குரலைக் கேட்டு அஞ்சி ஓடுவது எது?", "options": ["உழைமான்","கவரிமான்","கலைமான்","செந்நாய்"], "answer": "உழைமான்" },
{ "q": "குருளைக்குத் தன் நிழல் தந்த விலங்கு எது?", "options": ["உழைமான்","செந்நாய்","மந்தி","வானரம்"], "answer": "செந்நாய்" },
{ "q": "அடுப்பிடு சாந்த மோடு அகிலின் நாற்றமும் துடுப்பிடு மைவனச் சோற்றின் நாற்றமும் ……………. இவ் அடிகளில் உள்ள நயங்கள்.", "options": ["அடியெதுகை, அடிஇயைபு","சீர்மோனை, சீர்எதுகை","அடிமோனை, அடிஇயைபு","சீர்மோனை, சீர்இயைபு"], "answer": "அடியெதுகை, அடிஇயைபு" },
{ "q": "திருமாலை வழிபட்டு சிறப்புநிலை எய்தியவர்கள் ……………..", "options": ["நாயன்மார்கள்","ஆழ்வார்கள்","சமணர்கள்","தேவர்கள்"], "answer": "ஆழ்வார்கள்" },
{ "q": "ஆண்டாள் யாருடைய வளர்ப்பு மகள்?", "options": ["நம்மாழ்வார்","பேயாழ்வார்","பெரியாழ்வார்","பூதத்தாழ்வார்"], "answer": "பெரியாழ்வார்" },


{ "q": "நாச்சியார் திருமொழியில் உள்ள பாடல்கள்", "options": ["110","140","120","150"], "answer": "140" },
{ "q": "ஆழ்வார்கள் பாடிய பாடல்களின் தொகுப்பு …………….. ஆகும்.", "options": ["பெரிய புராணம்","நாலாயிரதிவ்ய பிரபந்தம்","நளவெண்பா","பூதத்தாழ்வார்"], "answer": "நாலாயிரதிவ்ய பிரபந்தம்" },
{ "q": "“மதுரையார் மன்னன் அடிநிலை” – மதுரையார் மன்னன் யார்?", "options": ["கண்ணன்","கன்னன்","கோவலன்","நெடுஞ்செழியன்"], "answer": "கண்ணன்" },
{ "q": "கைத்தலம் இலக்கணக்குறிப்பு யாது?", "options": ["பண்புத்தொகை","வினைத்தொகை","இருபெயரொட்டுப் பண்புத்தொகை","உவமைத்தொகை"], "answer": "இருபெயரொட்டுப் பண்புத்தொகை" },
{ "q": "செய்தி கதையின் தலைமை மாந்தர் யார்?", "options": ["தங்கவேலு","மணி","பிலிப் போலஸ்கா","ஜானகிராமன்"], "answer": "பிலிப் போலஸ்கா" },
{ "q": "சாகித்ய அகாதெமி விருது பெற்ற ஜானகிராமனின் நூல் எது?", "options": ["சக்தி வைத்தியம்","கருங்கடலும் கலைக்கடலும்","நடந்தாய் வாழி காவேரி","அடுத்த வீடு ஐம்பது மைல்"], "answer": "சக்தி வைத்தியம்" },
{ "q": "அப்பாவின் சிநேகிதர் நூலின் ஆசிரியர்", "options": ["அகிலன்","அசோகமித்திரன்","ஆதவன்","நாஞ்சில் நாடன்"], "answer": "அசோகமித்திரன்" },
{ "q": "தி.ஜானகிராமன் சாகித்ய அகாதெமி விருது பெற்ற ஆண்டு", "options": ["1969","1979","1989","1999"], "answer": "1979" },
{ "q": "செய்தி என்னும் சிறுகதை இடம் பெற்ற நூல் எது", "options": ["சிவப்பு ரிக்ஷா","மின்சாரப்பூ","ஒரு சிறு இசை","முதலில் இரவு வரும்"], "answer": "சிவப்பு ரிக்ஷா" },



{ "q": "மரவேர் என்பது ……………. புணர்ச்சி", "options": ["இயல்பு","திரிதல்","தோன்றல்","கெடுதல்"], "answer": "கெடுதல்" },
{ "q": "எழுத்து வகையால் சொற்கள் ………… வகைப்படும்.", "options": ["2","3","4","5"], "answer": "4" },
{ "q": "நிலை மொழி ஈற்றில் இ, ஈ, ஐ வரும் போது இடம்பெறும் உடம்படுமெய் …………..", "options": ["யகர உடம்படுமெய்","வகர உடம்படுமெய்","இரண்டும் வரும்","இரண்டும் வராது"], "answer": "யகர உடம்படுமெய்" },
{ "q": "வட்டு + ஆடினான் = எவ்வகை புணர்ச்சியில் வரும்?", "options": ["பண்புப்பெயர்ப் புணர்ச்சி","குற்றியலுகரப்புணர்ச்சி","இயல்பு புணர்ச்சி","திசைப்பெயர் புணர்ச்சி"], "answer": "குற்றியலுகரப்புணர்ச்சி" },
{ "q": "அடுக்கிய கோடி பெறினும் குன்றுவ செய்யாதவர்", "options": ["குடிஇழிந்தார்","குடி இறந்தார்","குடிப்பிறந்தார்","குடிமகிழந்தார்"], "answer": "குடிப்பிறந்தார்" },
{ "q": "ஊழி பெயரினும் தான் பெயராதவர்", "options": ["பொய்மையுடையவர்","இழித்தன்மையுடையவர்","சான்றாண்மையுடையவர்","கொடுங்கோலர்"], "answer": "சான்றாண்மையுடையவர்" },
