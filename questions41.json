{ "q": "‘ஆர்யபட்டா’ என்ற இந்திய முதல் செயற்கைக்கோளை ஏவுவதற்கு காரணமானவர் ………………..", "options": ["விக்ரம் சாராபாய்", "விஸ்வேஸ்வரய்யா", "கிரண்குமார்", "ராதாகிருஷ்ணன்"], "answer": "விக்ரம் சாராபாய்" },
{ "q": "திருவனந்தபுரத்தில் செயல்பட்டு வரும் ஆய்வு மையம்……………….", "options": ["பாபா அணு ஆராய்ச்சி மையம்", "இந்திரா காந்தி அணு ஆராய்ச்சி மையம்", "சதீஷ் தவன் விண்வெளி ஏவுதள மையம்", "விக்ரம் சாராபாய் விண்வெளி மையம்"], "answer": "விக்ரம் சாராபாய் விண்வெளி மையம்" },
