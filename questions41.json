{ "q": "அரிக்கமேடு அகழாய்வில் கண்டுபிடிக்கப்பட்டது எது?", "options": ["கற்கருவிகள்","ரோமானிய மட்பாண்டங்கள்","பழங்காசுகள்","எலும்புகள்"], "answer": "ரோமானிய மட்பாண்டங்கள்" },
{ "q": "சென்னைப் பல்லாவரத்தில் கற்கருவி கண்டுபிடித்த தொல்லியல் அறிஞர் யார்?", "options": ["ஜான் மார்ஷல்","இராபர்ட் புரூஸ்புட்","அலெக்சாண்டர்","கன்னிங்காம்"], "answer": "இராபர்ட் புரூஸ்புட்" },
{ "q": "இந்தியாவில் கண்டெடுக்கப்பட்ட முதல் கல்லாயுதம் எங்கு கண்டுபிடிக்கப்பட்டது?", "options": ["அரிக்கமேடு","கீழடி","பல்லாவரம்","கோவை"], "answer": "பல்லாவரம்" },
