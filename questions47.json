{ "q": "“தார்” என்பதற்கு பொருள் எது?", "options": ["மாலை","கிரீடம்","ஆடை","பூ"], "answer": "மாலை" },
{ "q": "“முடி” என்பதற்கு பொருள் எது?", "options": ["கிரீடம்","தலை","முடிவு","முடி (hair)"], "answer": "தலை" },
{ "q": "“முனிவு” என்பதற்கு பொருள் எது?", "options": ["மகிழ்ச்சி","சினம்","பயம்","துயரம்"], "answer": "சினம்" },
{ "q": "“அகத்து உவகை” என்பதற்கு பொருள் எது?", "options": ["வெளிப்புற மகிழ்ச்சி","மனமகிழ்ச்சி","துக்கம்","பயம்"], "answer": "மனமகிழ்ச்சி" },
{ "q": "“தமர்” என்பதற்கு பொருள் எது?", "options": ["நண்பர்கள்","பகைவர்கள்","உறவினர்","ஆசிரியர்"], "answer": "உறவினர்" },
{ "q": "“நீபவனம்” என்பதற்கு பொருள் எது?", "options": ["பூங்கா","கடம்பவனம்","காடு","தோட்டம்"], "answer": "கடம்பவனம்" },
{ "q": "“மீனவன்” என்பதற்கு பொருள் எது?", "options": ["மீனவர்","வேட்டைக்காரன்","பாண்டிய மன்னன்","கடற்கரை வாழ்வோர்"], "answer": "பாண்டிய மன்னன்" },
{ "q": "“கவரி” என்பதற்கு பொருள் எது?", "options": ["விசிறி","சாமரை","கொடி","குடை"], "answer": "சாமரை" },
{ "q": "“நுவன்ற” என்பதற்கு பொருள் எது?", "options": ["கேட்ட","சொல்லிய","செய்த","பார்த்த"], "answer": "சொல்லிய" },
{ "q": "“என்னா” என்பதற்கு பொருள் எது?", "options": ["வினா சொல்","பெயர்சொல்","அசைச்சொல்","வினைச்சொல்"], "answer": "அசைச்சொல்" },

{ "q": "கரகாட்டம் மற்றொரு பெயர் என்ன?", "options": ["கூத்தாட்டம்","கும்பாட்டம்","புலியாட்டம்","மயிலாட்டம்"], "answer": "கும்பாட்டம்" },
{ "q": "கரகாட்டம் மேலும் எந்த பெயரில் அழைக்கப்படுகிறது?", "options": ["தெருக்கூத்து","குடக்கூத்து","காவடியாட்டம்","தப்பாட்டம்"], "answer": "குடக்கூத்து" },
{ "q": "ஆயக்கலைகள் எத்தனை?", "options": ["32","64","100","108"], "answer": "64" },
{ "q": "கரகாட்டத்தின் துணையாட்டம் எது?", "options": ["புலியாட்டம்","மயிலாட்டம்","தப்பாட்டம்","தெருக்கூத்து"], "answer": "மயிலாட்டம்" },
{ "q": "தமிழ் மக்களின் வீரத்தைச் சொல்லும் கலை எது?", "options": ["மயிலாட்டம்","தப்பாட்டம்","புலி ஆட்டம்","காவடியாட்டம்"], "answer": "புலி ஆட்டம்" },
{ "q": "தப்பாட்டம் மற்றொரு பெயர் என்ன?", "options": ["பறை","தவில்","முரசு","உடுக்கை"], "answer": "பறை" },
{ "q": "ந.முத்துசாமிக்கு வழங்கப்பட்ட விருது எது?", "options": ["பாரத ரத்னா","கலைமாமணி","பத்மஸ்ரீ","கலைஞர் விருது"], "answer": "கலைமாமணி" },
{ "q": "நாட்டுப்புற மக்களால் நிகழ்த்தப்படும் கலை எது?", "options": ["தெருக்கூத்து","பாரதநாட்டியம்","கச்சேரி","நாடகம்"], "answer": "தெருக்கூத்து" },
{ "q": "நிகழ்கலை என்றால் என்ன?", "options": ["புத்தகக் கலை","மேடை நாடகம்","வாழ்வியல் நிகழ்வுகளுடன் இணைந்த கலை","ஓவியக்கலை"], "answer": "வாழ்வியல் நிகழ்வுகளுடன் இணைந்த கலை" },
{ "q": "தப்பாட்டம் என்பது என்ன?", "options": ["ஓவியம்","இசை மட்டும்","தப்பு கருவியுடன் ஆடும் கலை","பாடல்"], "answer": "தப்பு கருவியுடன் ஆடும் கலை" },
{ "q": "“கா” என்பதன் பொருள் என்ன?", "options": ["நடனம்","கோல்","இசை","உடை"], "answer": "கோல்" },
{ "q": "காவடியாட்டம் என்பது என்ன?", "options": ["பாடல்","கோலைத் தோளில் சுமந்து ஆடும் கலை","ஓவியம்","நாடகம்"], "answer": "கோலைத் தோளில் சுமந்து ஆடும் கலை" },
{ "q": "தப்பாட்டம் எங்கு ஆடப்படுகிறது?", "options": ["பள்ளி மட்டும்","கோவில் மட்டும்","பல நிகழ்வுகளில்","வீட்டில் மட்டும்"], "answer": "பல நிகழ்வுகளில்" },
{ "q": "கீழ்கண்டவற்றில் தப்பாட்டம் ஆடப்படும் இடம் எது?", "options": ["கோவில் திருவிழா","திருமணம்","விழிப்புணர்வு முகாம்","மேலே அனைத்தும்"], "answer": "மேலே அனைத்தும்" },
{ "q": "“நீரற வறியாக் கரகத்து” என்ற வரி எந்த நூலில்?", "options": ["திருக்குறள்","புறநானூறு","அகநானூறு","சிலப்பதிகாரம்"], "answer": "புறநானூறு" },
{ "q": "கரகம் என்பது எதைக் குறிக்கும்?", "options": ["நடனம்","குடம்","பாடல்","இசை"], "answer": "குடம்" },
{ "q": "புலியாட்டம் எதை பிரதிபலிக்கிறது?", "options": ["மகிழ்ச்சி","வீரத்தைக்","துக்கம்","பயம்"], "answer": "வீரத்தைக்" },
{ "q": "தெருக்கூத்து எங்கு நடைபெறும்?", "options": ["மேடையில்","தெருவில்","அரங்கில்","பள்ளியில்"], "answer": "தெருவில்" },
{ "q": "தப்பு என்பது எது?", "options": ["இசைக்கருவி","ஆடை","நடனம்","உணவு"], "answer": "இசைக்கருவி" },
{ "q": "கரகாட்டம் பொதுவாக எப்போது ஆடப்படுகிறது?", "options": ["தேர்வு நேரம்","விழாக்கள்","பள்ளி நேரம்","அலுவலகம்"], "answer": "விழாக்கள்" },


{ "q": "கவிஞர் உமா மேகஸ்வரி பிறந்த மாவட்டம் எது?", "options": ["தேனி","மதுரை","சென்னை","திருச்சி"], "answer": "மதுரை" },
{ "q": "உமா மேகஸ்வரி தற்போது எங்கு வாழ்கிறார்?", "options": ["சென்னை","கோயம்புத்தூர்","தேனி – ஆண்டிபட்டி","மதுரை"], "answer": "தேனி – ஆண்டிபட்டி" },
{ "q": "“பண்டி” என்பதற்கு பொருள் என்ன?", "options": ["தலை","வயிறு","கை","கால்"], "answer": "வயிறு" },
{ "q": "“அசும்பிய” என்பதன் பொருள் என்ன?", "options": ["இருள்","ஒளிவீசுகிற","சத்தம்","குளிர்"], "answer": "ஒளிவீசுகிற" },
{ "q": "“முச்சி” என்பதன் பொருள் என்ன?", "options": ["முடி","தலையுச்சி கொண்டை","தலை","முகம்"], "answer": "தலையுச்சி கொண்டை" },
{ "q": "சந்தத்துடன் உள்ள பாடலில் அதிகமாக இருப்பது எது?", "options": ["உணர்ச்சி","உயிர்ப்பு","சோகம்","சிந்தனை"], "answer": "உயிர்ப்பு" },
{ "q": "முத்துக்குமாரசாமி பிள்ளைத் தமிழை இயற்றியவர் யார்?", "options": ["கம்பர்","பாரதி","குமரகுருபரர்","அவ்வையார்"], "answer": "குமரகுருபரர்" },
{ "q": "முத்துக்குமாரசாமி பிள்ளைத்தமிழ் எதில் அடங்கும்?", "options": ["சங்க இலக்கியம்","96 சிற்றிலக்கியங்கள்","புராணம்","நாவல்"], "answer": "96 சிற்றிலக்கியங்கள்" },
{ "q": "குமரகுருபரின் காலம் எது?", "options": ["15ம் நூற்றாண்டு","16ம் நூற்றாண்டு","17ம் நூற்றாண்டு","18ம் நூற்றாண்டு"], "answer": "17ம் நூற்றாண்டு" },
{ "q": "ஆண்பாற் பிள்ளைத்தமிழின் கடைசி பருவம் எது?", "options": ["சிற்றில்","சிறுபறை","சிறுதேர்","மேலே அனைத்தும்"], "answer": "மேலே அனைத்தும்" },
{ "q": "பெண்பாற் பிள்ளைத்தமிழின் இறுதி பருவங்கள் எவை?", "options": ["கழங்கு, அம்மானை, ஊசல்","சிற்றில், சிறுபறை","ஊசல் மட்டும்","அம்மானை மட்டும்"], "answer": "கழங்கு, அம்மானை, ஊசல்" },
{ "q": "கம்பர் இராமன் வரலாற்றை எந்த பெயரில் எழுதியார்?", "options": ["இராமாயணம்","இராமாவதாரம்","சிலப்பதிகாரம்","பாரதம்"], "answer": "இராமாவதாரம்" },
{ "q": "இராமாவதாரம் மற்றொரு பெயர் என்ன?", "options": ["பாரதம்","கம்பராமாயணம்","கீதா","புராணம்"], "answer": "கம்பராமாயணம்" },
{ "q": "கம்பராமாயணப் பாடல்கள் எதனால் சிறப்பானவை?", "options": ["பொருள்","சந்தநயம்","கதை","வரலாறு"], "answer": "சந்தநயம்" },
{ "q": "கம்பர் எந்த ஊரைச் சேர்ந்தவர்?", "options": ["மதுரை","திருவழுந்தூர்","சென்னை","தஞ்சாவூர்"], "answer": "திருவழுந்தூர்" },
{ "q": "கம்பர் யாரால் ஆதரிக்கப்பட்டார்?", "options": ["ராஜா","சடையப்ப வள்ளல்","பாரதி","கலைஞர்"], "answer": "சடையப்ப வள்ளல்" },
{ "q": "பாரதி கம்பரைப் பற்றி என்ன கூறுகிறார்?", "options": ["அவர் கவிஞர்","நான் கம்பன்","கம்பன் இசைத்த கவியெல்லாம் நான்","அவர் அரசர்"], "answer": "கம்பன் இசைத்த கவியெல்லாம் நான்" },
{ "q": "சா.கந்தசாமி புகழ்பெற்ற புதினம் எது?", "options": ["விசாரணை கமிஷன்","சாயாவனம்","தேன்மழை","குறள்"], "answer": "சாயாவனம்" },
{ "q": "சா.கந்தசாமி சாகித்திய அகாதமி பெற்ற நூல்?", "options": ["சாயாவனம்","விசாரணை கமிஷன்","குறள்","நாவல்"], "answer": "விசாரணை கமிஷன்" },
{ "q": "“தேன்மழை” எழுதியவர் யார்?", "options": ["பாரதி","சுரதா","கம்பர்","அவ்வையார்"], "answer": "சுரதா" },
{ "q": "“திருக்குறள் நீதி இலக்கியம்” எழுதியவர்?", "options": ["கம்பர்","க.த.திருநாவுக்கரசு","பாரதி","சுரதா"], "answer": "க.த.திருநாவுக்கரசு" },
{ "q": "“நாட்டார் கலைகள்” எழுதியவர்?", "options": ["பெருமாள்","அ.கா.பெருமாள்","பாரதி","கம்பர்"], "answer": "அ.கா.பெருமாள்" },
{ "q": "“பொருளல் லவரைப்…” குறளில் வரும் அணி எது?", "options": ["உவமை","வஞ்சப் புகழ்ச்சி","சொல் பின்வருநிலை","யாப்பு"], "answer": "சொல் பின்வருநிலை" },
{ "q": "“குன்றேறி யானைப்போர்…” குறளில் வரும் அணி?", "options": ["உவமை","வஞ்சம்","சொல்","யாப்பு"], "answer": "உவமை" },
{ "q": "“தேவர் அனையர்…” குறளில் வரும் அணி?", "options": ["உவமை","வஞ்சப் புகழ்ச்சி","சொல்","இயைபு"], "answer": "வஞ்சப் புகழ்ச்சி" },
{ "q": "“சொல்லப் பயன்படுவர்…” குறளில் வரும் அணி?", "options": ["உவமை","வஞ்சம்","சொல்","இயைபு"], "answer": "உவமை" }

]

   
